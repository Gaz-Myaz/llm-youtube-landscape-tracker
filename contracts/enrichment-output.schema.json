{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/contracts/enrichment-output.schema.json",
  "title": "Video Enrichment Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "video_id",
    "provider",
    "model",
    "prompt_version",
    "primary_speaker",
    "summary",
    "content_type",
    "topics",
    "evidence",
    "confidence_score"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "video_id": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "primary_speaker": { "type": ["string", "null"] },
    "summary": { "type": "string", "minLength": 1 },
    "content_type": {
      "type": "string",
      "enum": ["news", "tutorial", "benchmark", "opinion", "demo", "interview", "research", "unknown"]
    },
    "stance": { "type": ["string", "null"] },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "label", "relevance_score"],
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "label": { "type": "string", "minLength": 1 },
          "relevance_score": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field_name", "quote"],
        "properties": {
          "field_name": { "type": "string", "minLength": 1 },
          "topic_slug": { "type": ["string", "null"] },
          "quote": { "type": "string", "minLength": 1 },
          "start_seconds": { "type": ["number", "null"], "minimum": 0 },
          "end_seconds": { "type": ["number", "null"], "minimum": 0 },
          "confidence_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
        }
      }
    },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "raw_response": { "type": ["object", "null"] }
  }
}
