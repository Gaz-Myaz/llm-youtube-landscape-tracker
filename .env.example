# Template only. Do not commit real secrets here.
# The worker reads process environment variables; export these values in your shell
# or set them as GitHub Actions repository secrets before running.
DATABASE_URL=postgresql://llm_tracker:llm_tracker@localhost:5432/llm_tracker
WORKER_PROVIDER=mock
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash
GEMINI_INPUT_USD_PER_1M_TOKENS=0.30
GEMINI_OUTPUT_USD_PER_1M_TOKENS=2.50
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_INPUT_USD_PER_1M_TOKENS=0.80
ANTHROPIC_OUTPUT_USD_PER_1M_TOKENS=4.00
OPENAI_INPUT_USD_PER_1M_TOKENS=0.40
OPENAI_OUTPUT_USD_PER_1M_TOKENS=1.60
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
MAX_VIDEOS_PER_RUN=25
MAX_PROVIDER_CALLS_PER_RUN=50
VIDEOS_PER_CHANNEL=5
TRANSCRIPT_REQUEST_DELAY_SECONDS=0.75
TRANSCRIPT_PROVIDERS=youtube_transcript_api,yt_dlp
YT_DLP_COOKIES_PATH=
